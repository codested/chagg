<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 2rem auto; max-width: 900px; line-height: 1.5; color: #111827; }
    h1, h2, h3 { margin-top: 1.5rem; margin-bottom: 0.6rem; }
    ul { margin-top: 0.2rem; }
    li { margin: 0.35rem 0; }
    .date { color: #6b7280; font-size: 0.95rem; }
    p.doc { white-space: pre-wrap; }
  </style>
</head>
<body>
  <h1>{{ .Title }}</h1>
  {{ if .Module }}<p>Module: {{ .Module }}</p>{{ end }}
  {{ range .Groups }}
  <section>
    <h2>{{ .Heading }}</h2>
    {{ if .Date }}<p class="date">{{ .Date }}</p>{{ end }}
    {{ range .DocsBlock }}
    <p class="doc">{{ . }}</p>
    {{ end }}
    {{ range .TypeGroups }}
    <h3>{{ .Title }}</h3>
    <ul>
      {{ range .Entries }}<li>{{ . }}</li>{{ end }}
    </ul>
    {{ end }}
  </section>
  {{ end }}
</body>
</html>

